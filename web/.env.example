# Google Sheets API — Service Account key (JSON encodé en base64)
# Commande : base64 -w 0 service-account.json
GOOGLE_SERVICE_ACCOUNT_KEY=

# ID du Google Spreadsheet (dans l'URL : /spreadsheets/d/{ID}/edit)
GOOGLE_SHEETS_ID=

# Anthropic API key (https://console.anthropic.com — requis pour le scoring IA et la recherche)
ANTHROPIC_API_KEY=

# Fullenrich API key (https://app.fullenrich.com)
FULLENRICH_API_KEY=

# Pappers API key — optionnel (https://www.pappers.fr/api)
# 100 crédits gratuits à l'inscription avec email pro
PAPPERS_API_KEY=
