# === Clés API ===

# Fullenrich — enrichissement de contacts
FULLENRICH_API_KEY=votre_cle_fullenrich

# Claude (Anthropic) — scoring IA avec Haiku
ANTHROPIC_API_KEY=votre_cle_anthropic

# HubSpot — CRM + envoi d'emails + tracking
# Créer un Private App dans HubSpot > Settings > Integrations > Private Apps
# Scopes requis : crm.objects.contacts.write, crm.objects.contacts.read,
#                 sales-email-read, sales-email-write
HUBSPOT_ACCESS_TOKEN=votre_token_hubspot

# Google Sheets — export des résultats
# Le fichier credentials.json doit être à la racine du projet
# (obtenu via Google Cloud Console > API Sheets > OAuth2)
GOOGLE_SHEETS_ID=votre_id_google_sheets
